{
  "id": "com.dcc-mcp.photoshop-bridge",
  "name": "dcc-mcp Bridge",
  "version": "0.1.0",
  "manifestVersion": 5,
  "main": "index.html",
  "host": {
    "app": "PS",
    "minVersion": "22.0.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "mainPanel",
      "label": {
        "default": "dcc-mcp Bridge"
      },
      "minimumSize": { "width": 200, "height": 120 },
      "maximumSize": { "width": 600, "height": 400 },
      "preferredDockedSize": { "width": 300, "height": 160 },
      "preferredFloatingSize": { "width": 300, "height": 160 }
    }
  ],
  "requiredPermissions": {
    "network": {
      "domains": "all"
    },
    "localFileSystem": "request"
  }
}
